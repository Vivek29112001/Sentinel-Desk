{
  "name": "desktop-agent-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop system monitoring tool built with Next.js and Electron",
  "author": "Vivek Sharma",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron": "electron electron/main.js",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron\"",
    "build": "next build",
    "electron-build": "electron-builder",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.sentineldesk.app",
    "productName": "SentinelDesk",
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-force-graph": "^1.48.2",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
